  },
  "dependencies": {
    "@even/core": "workspace:*",
    "@even/store": "workspace:*",
    "@even/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "tsx": "^4.16.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
